{
  "swagger": "2.0",
  "info": {
    "title": "Basic Calculator",
    "description": "Arithmetic operations over HTTP!",
    "version": "1.0"
  },
  "host": "fastapi-calculadora.onrender.com",
  "basePath": "/calculo-basico",
  "schemes": [
    "https"
  ],
  "produces": [
    "application/xml"
  ],
  "paths": {
    "/sumar/": {
      "get": {
        "description": "Responds with the sum of two numbers.",
        "operationId": "Add two integers",
        "parameters": [
          { "name": "num1", "in": "query", "required": true, "type": "integer", "default": 51 },
          { "name": "num2", "in": "query", "required": true, "type": "integer", "default": 49 }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "schema": {
              "$ref": "#/definitions/CalculationResult"
            },
            "examples": {
              "application/xml": "<CalculationResult><result>100</result></CalculationResult>"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "CalculationResult": {
      "type": "object",
      "xml": {
        "name": "CalculationResult"
      },
      "properties": {
        "result": {
          "type": "integer",
          "example": 100
        }
      }
    }
  }
}
