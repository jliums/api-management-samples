{
  "swagger": "2.0",
  "info": {
    "title": "Calculator",
    "description": "Arithmetics over HTTP!",
    "version": "1.0"
  },
  "host": "https://fastapi-calculadora.onrender.com/",
  "basePath": "/api",
  "schemes": [
    "http"
  ],
  "paths": {
    "/calculo-basico/sumar/": {
      "get": {
        "description": "Responds with a sum of two numbers.",
        "operationId": "Add two integers",
        "parameters": [
          {
            "name": "a",
            "in": "query",
            "description": "First operand.",
            "required": true,
            "type": "integer",
            "default": 51
          },
          {
            "name": "b",
            "in": "query",
            "description": "Second operand.",
            "required": true,
            "type": "integer",
            "default": 49
          }
        ],
        "responses": {
          "200": {
            "description": "Returns the sum"
          }
        }
      }
    },
    "/calculo-basico/restar/": {
      "get": {
        "description": "Responds with a difference between two numbers.",
        "operationId": "Subtract two integers",
        "parameters": [
          {
            "name": "a",
            "in": "query",
            "description": "First operand.",
            "required": true,
            "type": "integer",
            "default": 100
          },
          {
            "name": "b",
            "in": "query",
            "description": "Second operand.",
            "required": true,
            "type": "integer",
            "default": 50
          }
        ],
        "responses": {
          "200": {
            "description": "Returns the difference"
          }
        }
      }
    },
    "/calculo-basico/dividir/": {
      "get": {
        "description": "Responds with a quotient of two numbers.",
        "operationId": "Divide two integers",
        "parameters": [
          {
            "name": "a",
            "in": "query",
            "description": "First operand.",
            "required": true,
            "type": "integer",
            "default": 100
          },
          {
            "name": "b",
            "in": "query",
            "description": "Second operand.",
            "required": true,
            "type": "integer",
            "default": 20
          }
        ],
        "responses": {
          "200": {
            "description": "Returns the quotient"
          }
        }
      }
    },
    "/calculo-basico/multiplicar/": {
      "get": {
        "description": "Responds with a product of two numbers.",
        "operationId": "Multiply two integers",
        "parameters": [
          {
            "name": "a",
            "in": "query",
            "description": "First operand.",
            "required": true,
            "type": "integer",
            "default": 20
          },
          {
            "name": "b",
            "in": "query",
            "description": "Second operand.",
            "required": true,
            "type": "integer",
            "default": 5
          }
        ],
        "responses": {
          "200": {
            "description": "Returns the product"
          }
        }
      }
    }
  }
}
