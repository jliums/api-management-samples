{
  "swagger": "2.0",
  "info": {
    "title": "Calculator",
    "description": "Arithmetic operations over HTTP!",
    "version": "1.0"
  },
  "host": "fastapi-calculadora.onrender.com",
  "basePath": "/",
  "schemes": [
    "https"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/calculo-basico/sumar/": {
      "get": {
        "description": "Responds with the sum of two numbers.",
        "operationId": "Add two integers",
        "parameters": [
          {
            "name": "num1",
            "in": "query",
            "description": "First operand. Default value is <code>51</code>.",
            "required": true,
            "default": "51"
          },
          {
            "name": "num2",
            "in": "query",
            "description": "Second operand. Default value is <code>49</code>.",
            "required": true,
            "default": "49"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        }
      }
    },
    "/calculo-basico/restar/": {
      "get": {
        "description": "Responds with the difference between two numbers.",
        "operationId": "Subtract two integers",
        "parameters": [
          {
            "name": "num1",
            "in": "query",
            "required": true,
            "type": "integer",
            "default": 7
          },
          {
            "name": "num2",
            "in": "query",
            "required": true,
            "type": "integer",
            "default": 2
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        }
      }
    },
    "/calculo-basico/dividir/": {
      "get": {
        "description": "Responds with the quotient of two numbers.",
        "operationId": "Divide two integers",
        "parameters": [
          {
            "name": "num1",
            "in": "query",
            "required": true,
            "type": "integer",
            "default": 10
          },
          {
            "name": "num2",
            "in": "query",
            "required": true,
            "type": "integer",
            "default": 2
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        }
      }
    },
    "/calculo-basico/multiplicar/": {
      "get": {
        "description": "Responds with the product of two numbers.",
        "operationId": "Multiply two integers",
        "parameters": [
          {
            "name": "num1",
            "in": "query",
            "required": true,
            "type": "integer",
            "default": 4
          },
          {
            "name": "num2",
            "in": "query",
            "required": true,
            "type": "integer",
            "default": 6
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        }
      }
    }
  }
}
