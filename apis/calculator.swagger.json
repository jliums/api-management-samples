{
  "swagger": "2.0",
  "info": {
    "title": "Calculator",
    "description": "Arithmetic operations over HTTP!",
    "version": "1.0"
  },
  "host": "fastapi-calculadora.onrender.com",
  "basePath": "/api",
  "schemes": [
    "http",
    "https"
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/calculo-basico/sumar/": {
      "get": {
        "tags": ["Basic Arithmetic"],
        "description": "Responds with the sum of two numbers.",
        "operationId": "addIntegers",
        "parameters": [
          {
            "name": "a",
            "in": "query",
            "description": "First operand.",
            "required": true,
            "type": "integer",
            "default": 51
          },
          {
            "name": "b",
            "in": "query",
            "description": "Second operand.",
            "required": true,
            "type": "integer",
            "default": 49
          }
        ],
        "responses": {
          "200": {
            "description": "Returns the sum",
            "schema": {
              "type": "integer"
            }
          }
        }
      }
    },
    "/calculo-basico/restar/": {
      "get": {
        "tags": ["Basic Arithmetic"],
        "description": "Responds with the difference between two numbers.",
        "operationId": "subtractIntegers",
        "parameters": [
          {
            "name": "a",
            "in": "query",
            "required": true,
            "type": "integer",
            "default": 100
          },
          {
            "name": "b",
            "in": "query",
            "required": true,
            "type": "integer",
            "default": 50
          }
        ],
        "responses": {
          "200": {
            "description": "Returns the difference",
            "schema": {
              "type": "integer"
            }
          }
        }
      }
    },
    "/calculo-basico/dividir/": {
      "get": {
        "tags": ["Basic Arithmetic"],
        "description": "Responds with the quotient of two numbers.",
        "operationId": "divideIntegers",
        "parameters": [
          {
            "name": "a",
            "in": "query",
            "required": true,
            "type": "integer",
            "default": 100
          },
          {
            "name": "b",
            "in": "query",
            "required": true,
            "type": "integer",
            "default": 20
          }
        ],
        "responses": {
          "200": {
            "description": "Returns the quotient",
            "schema": {
              "type": "number"
            }
          },
          "400": {
            "description": "Division by zero error"
          }
        }
      }
    },
    "/calculo-basico/multiplicar/": {
      "get": {
        "tags": ["Basic Arithmetic"],
        "description": "Responds with the product of two numbers.",
        "operationId": "multiplyIntegers",
        "parameters": [
          {
            "name": "a",
            "in": "query",
            "required": true,
            "type": "integer",
            "default": 20
          },
          {
            "name": "b",
            "in": "query",
            "required": true,
            "type": "integer",
            "default": 5
          }
        ],
        "responses": {
          "200": {
            "description": "Returns the product",
            "schema": {
              "type": "integer"
            }
          }
        }
      }
    }
  }
}
