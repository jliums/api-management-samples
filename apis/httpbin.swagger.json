{
    "swagger": "2.0",
    "info": {
        "title": "httpbin.org",
        "description": "API Management facade for a very handy and free online HTTP tool.",
        "version": "1.0"
    },
    "host": "httpbin",
    "basePath": "/",
    "schemes": [
        "http",
        "https"
    ],
    "produces": [
        "application/json"
    ],
    "paths": {
        "/status/{code}": {
            "get": {
                "description": "Returns provided HTTP Status code.",
                "operationId": "getStatus",
                "parameters": [{
                    "name": "code",
                    "in": "path",
                    "description": "HTTP code to return.",
                    "required": true,
                    "type": "integer",
                    "default": 200
                }],
                "responses": {
                    "200": { "description": "Returns the requested status code." }
                }
            }
        },
        "/get": {
            "get": {
                "description": "Returns GET data.",
                "operationId": "getBasicData",
                "responses": {
                    "200": { "description": "Successful request." }
                }
            }
        },
        "/post": {
            "post": {
                "description": "Returns POST data.",
                "operationId": "postData",
                "responses": {
                    "200": { "description": "Successful request." }
                }
            }
        },
        "/ip": {
            "get": {
                "description": "Returns origin IP.",
                "operationId": "getOriginIp",
                "responses": {
                    "200": { "description": "Returns a JSON object with the 'origin' IP address." }
                }
            }
        },
        "/user-agent": {
            "get": {
                "description": "Returns user agent string.",
                "operationId": "getUserAgent",
                "responses": {
                    "200": { "description": "Returns the user-agent header." }
                }
            }
        },
        "/headers": {
            "get": {
                "description": "Returns headers dictionary.",
                "operationId": "getRequestHeaders",
                "responses": {
                    "200": { "description": "Returns the header dictionary." }
                }
            }
        },
        "/delay/{seconds}": {
            "get": {
                "description": "Delays responding for n seconds (max 10).",
                "operationId": "delayResponse",
                "parameters": [{
                    "name": "seconds",
                    "in": "path",
                    "description": "The amount of time to delay.",
                    "required": true,
                    "type": "integer",
                    "default": 2
                }],
                "responses": {
                    "200": { "description": "Successful delayed response." }
                }
            }
        },
        "/cache/{maxAge}": {
            "get": {
                "operationId": "setCacheControl",
                "description": "Sets a Cache-Control header for n seconds.",
                "parameters": [{
                    "name": "maxAge",
                    "in": "path",
                    "description": "Max age value.",
                    "required": true,
                    "type": "integer",
                    "default": 10
                }],
                "responses": {
                    "200": { "description": "Cache-Control set successfully." }
                }
            }
        },
